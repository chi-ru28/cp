{
  "version": 2,
  "functions": {
    "backend/server.js": { "runtime": "@vercel/node" },
    "backend/main.py": { "runtime": "@vercel/python" }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "backend/server.js"
    },
    {
      "source": "/ai-api/(.*)",
      "destination": "backend/main.py"
    },
    {
      "source": "/(.*)",
      "destination": "frontend/$1"
    },
    {
      "source": "/(.*)",
      "destination": "frontend/index.html"
    }
  ]
}
