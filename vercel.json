{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "backend/api/index.js"
    },
    {
      "source": "/ai-api/(.*)",
      "destination": "backend/api/main.py"
    },
    {
      "source": "/(.*)",
      "destination": "frontend/$1"
    },
    {
      "source": "/(.*)",
      "destination": "frontend/index.html"
    }
  ]
}
