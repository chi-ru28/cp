def generate_solution(crop, issue, data):
    fertilizer = data[0]
    nutrient = data[1]
    quantity = data[2]
    stage = data[3]

    solution = f"""
Diagnosis:
Your {crop} crop may have {issue}.

Recommended Fertilizer:
{fertilizer}

Main Nutrient:
{nutrient}

Recommended Quantity:
{quantity} per acre

Application Stage:
{stage}

Organic Alternative:
Use compost or vermicompost.

Precaution:
Avoid excessive fertilizer application.
"""
    return solution
