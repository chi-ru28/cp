PORT=5000
NODE_ENV=development

# PostgreSQL connection (primary database)
# Set DATABASE_URL to connect to a hosted PostgreSQL (e.g. Supabase, Railway, Render, etc.)
# Example: DATABASE_URL=postgresql://user:password@host:5432/agriassist
DATABASE_URL=postgresql://postgres:1234@localhost:5432/AgriAssist

# Or use individual PostgreSQL credentials for a local server:
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=AgriAssist
POSTGRES_USER=postgres
POSTGRES_PASSWORD=1234

# If neither DATABASE_URL nor local PostgreSQL are available,
# the app automatically falls back to SQLite (stored in backend/agriassist.sqlite)

# Auth
JWT_SECRET=thisisasupersecretkeythatshouldbelongandunguessable123!
JWT_ACCESS_EXPIRATION_MINUTES=10080

# AI & External APIs
GEMINI_API_KEY=AIzaSyCSbPbGaF93-d-XNWZPmWfxtPudHKfBI5o
WEATHER_API_KEY=69a6f626eeed7a0008bd7972