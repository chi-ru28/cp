{
  "version": 2,
  "functions": {
    "server.js": { "runtime": "@vercel/node" },
    "main.py": { "runtime": "@vercel/python" }
  },
  "rewrites": [
    {
      "source": "/ai-api/(.*)",
      "destination": "main.py"
    },
    {
      "source": "/(.*)",
      "destination": "server.js"
    }
  ]
}
