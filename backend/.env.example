# AgriAssist Backend Environment Template
# Rename this file to .env and fill in your actual keys

# 1. Server Configuration
PORT=5000
NODE_ENV=development

# 2. Database Configuration
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://neondb_owner:YOUR_KEY@ep-aged-smoke-a1x581od.ap-southeast-1.aws.neon.tech/neondb?sslmode=require

# 3. Security
JWT_SECRET=your-super-long-secure-secret-key-123!

# 4. Third-Party APIs
# Get your keys from:
# OpenAI: https://platform.openai.com/
# OpenWeather: https://openweathermap.org/api
OPENAI_API_KEY=sk-proj-YOUR_OPENAI_KEY
WEATHER_API_KEY=YOUR_WEATHER_KEY
